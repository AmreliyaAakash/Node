<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900">
        <h3 class="text-3xl text-white">Login Your Account
        </h3>
        <form action="/login" method="post">
           
            <input type="email" name="email" placeholder="Email" class="bg-zinc-800 text-white p-2 rounded m-2">
            <input type="password" name="password" placeholder="Password" class="bg-zinc-800 text-white p-2 rounded m-2">
           
            <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">Login</button>
        </form>
    </div>
</body>
</html>