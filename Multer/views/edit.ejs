<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User</title>
</head>

<body style="font-family: Arial; background:#f4f4f4; padding:20px;">

    <h2>Edit User</h2>

    <form action="/update/<%= user._id %>" method="post" enctype="multipart/form-data"
        style="background:white; padding:20px; width:300px; border-radius:8px;">


        <input type="text" name="username" value="<%= user.username %>" required
            style="width:100%; padding:8px;"><br><br>


        <input type="password" name="password" value="<%= user.password %>" required
            style="width:100%; padding:8px;"><br><br>


        <p>Image:</p>
        <img src="/upload/<%= user.image %>" width="120" style="border-radius:8px;"><br><br>

        <input type="file" name="image"><br><br>


        <button type="submit" style="background:green; color:white; padding:8px 16px; border:none; border-radius:4px;">
            Update
        </button>

        <a href="/" style="margin-left:10px; text-decoration:none; color:blue;">
            Back
        </a>

    </form>

</body>

</html>